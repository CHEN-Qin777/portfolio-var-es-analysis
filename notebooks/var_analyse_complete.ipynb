# %% [markdown]
# # Analyse VaR et ES d'un portefeuille multi-actifs
# 
# Ce notebook exécute l'ensemble du pipeline : téléchargement des données, calcul des rendements, construction du portefeuille, calcul des VaR/ES historiques et Monte Carlo, visualisations et comparaison.

# %% Installation des dépendances
!pip install yfinance numpy pandas matplotlib scipy seaborn

# %% Import des modules
import numpy as np
import pandas as pd
import yfinance as yf
import matplotlib.pyplot as plt
import seaborn as sns

# %% Définition des fonctions (extrait des fichiers .py)
def telecharger_donnees(tickers, debut, fin):
    try:
        data = yf.download(tickers, start=debut, end=fin)['Adj Close']
        if data.empty:
            raise ValueError("Aucune donnée.")
        return data
    except:
        print("Utilisation de données synthétiques.")
        dates = pd.date_range(start=debut, end=fin, freq='B')
        prix = pd.DataFrame(index=dates)
        for t in tickers:
            prix[t] = 100 * (1 + np.random.randn(len(dates)).cumsum() / 100)
        return prix

def calculer_rendements(prix):
    return np.log(prix / prix.shift(1)).dropna()

class Portefeuille:
    def __init__(self, rendements, poids=None):
        self.rendements = rendements
        self.n_actifs = rendements.shape[1]
        if poids is None:
            self.poids = np.ones(self.n_actifs) / self.n_actifs
        else:
            self.poids = np.array(poids)
        self.rendements_portefeuille = rendements.dot(self.poids)

def var_historique(rendements, niveau=0.95):
    return np.percentile(rendements, 100*(1-niveau))

def es_historique(rendements, niveau=0.95):
    var = var_historique(rendements, niveau)
    return rendements[rendements <= var].mean()

def var_glissante(rendements, fenetre=252, niveau=0.95):
    vars_ = []
    for i in range(fenetre, len(rendements)):
        vars_.append(var_historique(rendements[i-fenetre:i], niveau))
    return np.array(vars_)

def var_montecarlo(rendements, poids, n_sim=10000, horizon=1, niveau=0.95):
    mu = rendements.mean().values
    cov = rendements.cov().values
    rendements_sim = np.random.multivariate_normal(mu * horizon, cov * horizon, n_sim)
    rendements_portefeuille = rendements_sim @ poids
    var = np.percentile(rendements_portefeuille, 100*(1-niveau))
    es = rendements_portefeuille[rendements_portefeuille <= var].mean()
    return var, es

# %% Téléchargement des données
tickers = ['AAPL', 'MSFT', 'GLD', 'TLT']
debut = '2015-01-01'
fin = '2023-12-31'
prix = telecharger_donnees(tickers, debut, fin)
rendements = calculer_rendements(prix)

# %% Construction du portefeuille équipondéré
port = Portefeuille(rendements)
rend_ptf = port.rendements_portefeuille

# %% Calcul VaR/ES historique
var_hist_95 = var_historique(rend_ptf, 0.95)
es_hist_95 = es_historique(rend_ptf, 0.95)
var_hist_99 = var_historique(rend_ptf, 0.99)
es_hist_99 = es_historique(rend_ptf, 0.99)

print(f"VaR 95% historique : {var_hist_95:.6f}")
print(f"ES 95% historique   : {es_hist_95:.6f}")
print(f"VaR 99% historique : {var_hist_99:.6f}")
print(f"ES 99% historique   : {es_hist_99:.6f}")

# %% Visualisation histogramme
plt.figure(figsize=(10,6))
sns.histplot(rend_ptf, bins=50, kde=True, stat='density')
plt.axvline(var_hist_95, color='red', linestyle='--', label=f'VaR 95% {var_hist_95:.4f}')
plt.axvline(es_hist_95, color='orange', linestyle='--', label=f'ES 95% {es_hist_95:.4f}')
plt.xlabel('Rendement')
plt.ylabel('Densité')
plt.title('Distribution des rendements du portefeuille')
plt.legend()
plt.show()

# %% VaR glissante
vars_gliss = var_glissante(rend_ptf, fenetre=252, niveau=0.95)
dates_gliss = rend_ptf.index[252:]

plt.figure(figsize=(12,6))
plt.plot(rend_ptf.index, rend_ptf, alpha=0.5, label='Rendements')
plt.plot(dates_gliss, vars_gliss, color='red', linewidth=2, label='VaR 95% glissante')
# Périodes de stress
crises = [('2008-09-15','2009-03-01'), ('2020-02-20','2020-04-01')]
for d,f in crises:
    plt.axvspan(pd.to_datetime(d), pd.to_datetime(f), alpha=0.2, color='gray')
plt.legend()
plt.title('VaR historique glissante (fenêtre 1 an)')
plt.show()

# %% VaR Monte Carlo
var_mc, es_mc = var_montecarlo(rendements, port.poids, n_sim=50000, niveau=0.95)
print(f"VaR Monte Carlo 95% : {var_mc:.6f}")
print(f"ES Monte Carlo 95%  : {es_mc:.6f}")

# %% Comparaison des méthodes
print("\n--- Comparaison des méthodes (VaR 95%) ---")
print(f"Historique : {var_hist_95:.6f}")
print(f"Monte Carlo: {var_mc:.6f}")
